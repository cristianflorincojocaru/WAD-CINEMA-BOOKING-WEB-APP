@model IEnumerable<cinemawebapp.Models.Movie>

@{
    ViewData["Title"] = "Upcoming";
}

@section Styles {
    <style>
        .movie-card {
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
            background-color: #141414;
            border: 1px solid #1e1e1e;
            border-radius: 10px;
            overflow: hidden;
        }

            .movie-card:hover {
                transform: scale(1.03);
                box-shadow: 0 12px 30px rgba(0, 0, 0, 0.8);
                border-color: #8B1A1A;
            }

            .movie-card .card-body {
                padding: 12px 14px;
                background-color: #141414;
                border: 1px solid #1e1e1e;
                border-top-left-radius: 0;
                border-top-right-radius: 0;
                border-bottom-left-radius: 8px;
                border-bottom-right-radius: 8px;
                outline: none;
            }

            .movie-card .card-title {
                font-size: 14px;
                font-weight: bold;
                color: white;
                letter-spacing: 1px;
                margin-bottom: 4px;
            }

            .movie-card .card-text {
                font-size: 11px;
                color: #666;
                text-transform: uppercase;
                letter-spacing: 2px;
                margin-bottom: 0;
            }

        .movie-img-wrapper {
            position: relative;
            overflow: hidden;
        }

            .movie-img-wrapper img {
                width: 100%;
                height: auto;
                display: block;
                transition: all 0.35s ease;
            }

        .movie-card:hover img {
            transform: scale(1.1);
            filter: brightness(0.35);
        }

        .movie-overlay {
            position: absolute;
            inset: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 14px;
            opacity: 0;
            transition: opacity 0.35s ease;
            pointer-events: none;
        }

        .movie-card:hover .movie-overlay {
            opacity: 1;
        }

        .age-badge {
            position: absolute;
            top: 10px;
            right: 10px;
            background-color: #8B1A1A;
            color: white;
            font-size: 12px;
            font-weight: 700;
            padding: 3px 7px;
            border-radius: 4px;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .overlay-title {
            font-size: 15px;
            font-weight: 700;
            color: white;
            text-align: center;
            letter-spacing: 1px;
            text-transform: uppercase;
            margin-bottom: 8px;
            line-height: 1.3;
        }

        .overlay-genres {
            font-size: 13px;
            color: #ccc;
            text-transform: uppercase;
            letter-spacing: 2px;
            text-align: center;
            margin-bottom: 6px;
        }

        .overlay-duration {
            font-size: 12px;
            color: #999;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .section-divider {
            height: 1px;
            background: linear-gradient(to right, transparent, #2a2a2a, transparent);
            border: none;
            margin: 0 0 32px 0;
        }

        .no-results {
            display: none;
            text-align: center;
            padding: 80px 0;
            color: #444;
            font-size: 12px;
            letter-spacing: 3px;
            text-transform: uppercase;
        }

            .no-results span {
                display: block;
                font-size: 48px;
                margin-bottom: 16px;
                opacity: 0.3;
            }

        /* ── TAB BUTTONS ── */
        .tab-btn {
            position: relative;
            display: inline-block;
            padding: 12px 44px;
            font-size: 11px;
            font-weight: 900;
            letter-spacing: 3px;
            text-transform: uppercase;
            text-decoration: none;
            border-radius: 8px;
            border: 1px solid #2e2e2e;
            color: #555;
            background: #0d0d0d;
            overflow: hidden;
            transition: color 0.3s ease, border-color 0.3s ease, transform 0.25s ease, box-shadow 0.3s ease;
        }

            .tab-btn::before {
                content: '';
                position: absolute;
                inset: 0;
                background: linear-gradient(135deg, #C40000, #7a0000);
                transform: translateX(-101%);
                transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
                z-index: 0;
            }

            .tab-btn::after {
                content: '';
                position: absolute;
                top: 0;
                left: -60%;
                width: 40%;
                height: 100%;
                background: linear-gradient(90deg, transparent, rgba(255,255,255,0.06), transparent);
                transform: skewX(-20deg);
                transition: left 0.55s ease;
                z-index: 2;
                pointer-events: none;
            }

            .tab-btn span {
                position: relative;
                z-index: 1;
            }

            .tab-btn:hover {
                color: white;
                border-color: #C40000;
                transform: translateY(-3px);
                box-shadow: 0 8px 24px rgba(180,0,0,0.3);
            }

                .tab-btn:hover::before {
                    transform: translateX(0);
                }

                .tab-btn:hover::after {
                    left: 130%;
                }

            .tab-btn.active-tab {
                color: white;
                border-color: transparent;
                box-shadow: 0 6px 28px rgba(180,0,0,0.5);
                border-bottom: 2px solid #ff4444;
                animation: tabPulse 2.5s ease-in-out infinite;
            }

                .tab-btn.active-tab::before {
                    transform: translateX(0);
                }

        @@keyframes tabPulse {
            0%, 100% {
                box-shadow: 0 6px 28px rgba(180,0,0,0.5);
            }

            50% {
                box-shadow: 0 8px 36px rgba(200,0,0,0.8);
            }
        }

        /* ── MANAGE BUTTON ── */
        .btn-manage {
            background: linear-gradient(135deg, #B20000, #8B0000);
            border: none;
            color: white;
            font-weight: 900;
            letter-spacing: 3px;
            padding: 9px 24px;
            font-size: 11px;
            border-radius: 6px;
            text-transform: uppercase;
            text-decoration: none;
            box-shadow: 0 4px 18px rgba(178,0,0,0.45);
            transition: all 0.35s ease;
            display: inline-block;
            position: relative;
            overflow: hidden;
        }

            .btn-manage::after {
                content: '';
                position: absolute;
                top: 0;
                left: -80%;
                width: 50%;
                height: 100%;
                background: linear-gradient(90deg, transparent, rgba(255,255,255,0.12), transparent);
                transform: skewX(-15deg);
                transition: left 0.5s ease;
            }

            .btn-manage:hover {
                background: linear-gradient(135deg, #D40000, #A00000);
                box-shadow: 0 8px 32px rgba(210,0,0,0.65);
                transform: translateY(-2px) scale(1.03);
                color: white;
            }

                .btn-manage:hover::after {
                    left: 130%;
                }

        /* ── FILTER BAR ── */
        .filter-section {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px;
            margin-bottom: 36px;
        }

        .filter-label {
            font-size: 10px;
            letter-spacing: 5px;
            text-transform: uppercase;
            color: #aaa;
            position: relative;
        }

            .filter-label::before,
            .filter-label::after {
                content: '';
                position: absolute;
                top: 50%;
                width: 36px;
                height: 1px;
            }

            .filter-label::before {
                right: calc(100% + 12px);
                background: linear-gradient(to left, #aaa, transparent);
            }

            .filter-label::after {
                left: calc(100% + 12px);
                background: linear-gradient(to right, #aaa, transparent);
            }

        .filter-bar {
            display: flex;
            gap: 10px;
            align-items: center;
            flex-wrap: wrap;
            justify-content: center;
            background: #161616;
            border: 1px solid #303030;
            border-radius: 12px;
            padding: 18px 28px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.03);
        }

        .filter-select-wrap {
            position: relative;
        }

            .filter-select-wrap::after {
                content: '▾';
                position: absolute;
                right: 13px;
                top: 50%;
                transform: translateY(-50%);
                color: #666;
                pointer-events: none;
                font-size: 10px;
                transition: color 0.2s;
            }

            .filter-select-wrap:hover::after {
                color: #cc3333;
            }

        .filter-bar select {
            background: #202020;
            border: 1px solid #383838;
            color: #ccc;
            border-radius: 7px;
            font-size: 11px;
            letter-spacing: 2px;
            text-transform: uppercase;
            padding: 10px 34px 10px 15px;
            outline: none;
            transition: border-color 0.25s, color 0.25s, background 0.25s, box-shadow 0.25s;
            appearance: none;
            -webkit-appearance: none;
            cursor: pointer;
            min-width: 148px;
        }

            .filter-bar select:hover {
                border-color: #7a1a1a;
                color: #eee;
                background: #252525;
            }

            .filter-bar select:focus {
                border-color: #B20000;
                color: white;
                background: #252525;
                box-shadow: 0 0 0 3px rgba(178,0,0,0.15);
            }

        .filter-bar option {
            background: #1e1e1e;
        }

        .filter-duration-wrap {
            display: flex;
            align-items: center;
            gap: 14px;
            background: #202020;
            border: 1px solid #383838;
            border-radius: 7px;
            padding: 10px 18px;
            transition: border-color 0.25s, box-shadow 0.25s;
        }

            .filter-duration-wrap:hover {
                border-color: #7a1a1a;
                box-shadow: 0 0 0 3px rgba(178,0,0,0.1);
            }

            .filter-duration-wrap label {
                font-size: 11px;
                letter-spacing: 2px;
                text-transform: uppercase;
                color: #999;
                white-space: nowrap;
                transition: color 0.2s;
            }

            .filter-duration-wrap:hover label {
                color: #ccc;
            }

        #filterDuration {
            -webkit-appearance: none;
            appearance: none;
            width: 130px;
            height: 4px;
            border-radius: 2px;
            background: #333;
            outline: none;
            cursor: pointer;
            border: none;
            padding: 0;
        }

            #filterDuration::-webkit-slider-runnable-track {
                height: 4px;
                border-radius: 2px;
                background: transparent;
            }

            #filterDuration::-webkit-slider-thumb {
                -webkit-appearance: none;
                width: 20px;
                height: 20px;
                border-radius: 50%;
                background: radial-gradient(circle at 40% 35%, #e03030, #8B0000);
                margin-top: -8px;
                border: 2px solid #cc0000;
                box-shadow: 0 0 6px rgba(178,0,0,0.6);
                transition: box-shadow 0.2s, transform 0.2s;
                cursor: pointer;
            }

                #filterDuration::-webkit-slider-thumb:hover {
                    box-shadow: 0 0 14px rgba(200,0,0,0.9);
                    transform: scale(1.25);
                }

            #filterDuration::-moz-range-track {
                height: 4px;
                border-radius: 2px;
                background: #333;
            }

            #filterDuration::-moz-range-thumb {
                width: 20px;
                height: 20px;
                border-radius: 50%;
                background: #B20000;
                border: 2px solid #cc0000;
                box-shadow: 0 0 6px rgba(178,0,0,0.6);
                cursor: pointer;
            }

        #durationVal {
            font-size: 12px;
            color: #ddd;
            letter-spacing: 1px;
            white-space: nowrap;
            min-width: 55px;
            font-weight: 700;
        }

        .btn-reset {
            background: #1c1c1c;
            border: 1px solid #404040;
            color: #999;
            font-size: 11px;
            letter-spacing: 2px;
            text-transform: uppercase;
            padding: 10px 20px;
            border-radius: 7px;
            cursor: pointer;
            transition: all 0.25s;
            font-weight: 700;
            position: relative;
            overflow: hidden;
        }

            .btn-reset:hover {
                border-color: #B20000;
                color: #ff6666;
                background: #1f0a0a;
                box-shadow: 0 0 12px rgba(178,0,0,0.2);
                transform: translateY(-1px);
            }

            .btn-reset:active {
                transform: scale(0.97);
            }
    </style>
}

<div class="container mt-5 mb-5">

    <h1 class="mb-2 fw-bold text-uppercase text-center" style="letter-spacing:4px;">Movies</h1>
    <p class="text-center mb-4" style="color:#aaa; font-size:12px; letter-spacing:3px; text-transform:uppercase;">Coming to The Film Vault</p>

    <div class="text-end mb-3">
        @if (User.IsInRole("Admin"))
        {
            <a href="/Movies" class="btn-manage">⚙ Manage</a>
        }
    </div>

    <div class="d-flex justify-content-center gap-3 mb-4">
        <a href="/Home/Movies" class="tab-btn"><span>Now in Theaters</span></a>
        <a href="/Home/Upcoming" class="tab-btn active-tab"><span>Coming Soon</span></a>
    </div>

    <hr class="section-divider">

    <div class="filter-section">
        <div class="filter-label">Filter movies</div>
        <div class="filter-bar">
            <div class="filter-select-wrap">
                <select id="filterGenre"><option value="">All Genres</option></select>
            </div>
            <div class="filter-select-wrap">
                <select id="filterRating"><option value="">All Ratings</option></select>
            </div>
            <div class="filter-duration-wrap">
                <label for="filterDuration">Max Duration</label>
                <input type="range" id="filterDuration" min="60" max="240" value="240" step="10">
                <span id="durationVal">Any</span>
            </div>
            <button class="btn-reset" id="btnReset">✕ Reset</button>
        </div>
    </div>

    <div class="row g-4" id="movieGrid">
        @foreach (var movie in Model)
        {
            <div class="col-md-3 movie-item"
                 data-genre="@movie.Genre"
                 data-rating="@movie.AgeRating"
                 data-duration="@movie.DurationMinutes">
                <a href="/Home/MovieDetails/@movie.Id" class="text-decoration-none">
                    <div class="card movie-card">
                        <div class="movie-img-wrapper">
                            <img src="@movie.ImagePath" alt="@movie.Title">
                            <div class="movie-overlay">
                                <span class="age-badge">@movie.AgeRating</span>
                                <div class="overlay-title">@movie.Title</div>
                                <div class="overlay-genres">@movie.Genre</div>
                                <div class="overlay-duration">@movie.DurationMinutes min</div>
                            </div>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">@movie.Title</h5>
                            <p class="card-text">@movie.Genre</p>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>

    <div class="no-results" id="noResults">
        <span>🎬</span>No movies match your filters
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const items = document.querySelectorAll('.movie-item');
            const genreSelect = document.getElementById('filterGenre');
            const ratingSelect = document.getElementById('filterRating');
            const slider = document.getElementById('filterDuration');
            const durationVal = document.getElementById('durationVal');
            const noResults = document.getElementById('noResults');

            const genres = new Set(), ratings = new Set();
            let maxDur = 60;

            items.forEach(item => {
                item.dataset.genre.split('/').forEach(g => genres.add(g.trim()));
                ratings.add(item.dataset.rating.trim());
                const d = parseInt(item.dataset.duration);
                if (d > maxDur) maxDur = d;
            });

            [...genres].sort().forEach(g => {
                genreSelect.appendChild(Object.assign(document.createElement('option'), { value: g, textContent: g }));
            });
            [...ratings].sort().forEach(r => {
                ratingSelect.appendChild(Object.assign(document.createElement('option'), { value: r, textContent: r }));
            });

            slider.max = maxDur + 10;
            slider.value = slider.max;

            function updateTrack() {
                const pct = ((slider.value - slider.min) / (slider.max - slider.min)) * 100;
                slider.style.background = `linear-gradient(to right, #B20000 ${pct}%, #2e2e2e ${pct}%)`;
            }

            function applyFilters() {
                const genre = genreSelect.value;
                const rating = ratingSelect.value;
                const max = parseInt(slider.value);
                durationVal.textContent = max >= parseInt(slider.max) ? 'Any' : max + ' min';
                updateTrack();
                let visible = 0;
                items.forEach(item => {
                    const show = (!genre || item.dataset.genre.includes(genre))
                              && (!rating || item.dataset.rating.trim() === rating)
                              && parseInt(item.dataset.duration) <= max;
                    item.style.display = show ? '' : 'none';
                    if (show) visible++;
                });
                noResults.style.display = visible === 0 ? 'block' : 'none';
            }

            genreSelect.addEventListener('change', applyFilters);
            ratingSelect.addEventListener('change', applyFilters);
            slider.addEventListener('input', applyFilters);
            document.getElementById('btnReset').addEventListener('click', () => {
                genreSelect.value = ''; ratingSelect.value = ''; slider.value = slider.max;
                applyFilters();
            });

            updateTrack();
        })();
    </script>
}