    height: 100%;
    position: relative;
}
.hero-slide.active { display: flex; }
 
/* Imaginea — dreapta */
.hero-img {
    position: absolute;   /* 🔥 IMPORTANT */
    inset: 0;             /* ocupă tot banner-ul */
    width: 100%;
    height: 100%;
    object-fit: cover;    /* umple tot spațiul */
    object-position: 70% center; /* mută focusul imaginii */
    z-index: 0;           /* rămâne în spate */
}
 
/* Gradientul stânga → dreapta (dark + culoare) */
.hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
        to right,
        rgba(0, 0, 0, 0.95) 0%,
        rgba(40, 0, 0, 0.85) 40%,
