    z-index: 2;
    padding: 0 60px;
    max-width: 720px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    height: 100%;
}
.hero-title {
    font-size: 42px;
    font-weight: 900;
    color: white;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 14px;
    line-height: 1.1;
}
.hero-desc {
    font-size: 14px;                  /* puțin mai mare pentru lizibilitate */
    color: #dddddd;                   /* alb curat */
    line-height: 1.5;                 /* mai compact, dar încă lizibil */
    margin-bottom: 28px;
    max-width: 390px;                 /* lungime confortabilă pentru citire */
    letter-spacing: 0.5px;            /* puțin mai spațiat între litere pentru eleganță */
    font-weight: 500;                  /* semi-bold pentru “premium feel” */
    text-shadow: 0 1px 3px rgba(0,0,0,0.5); /* vizibilitate mai bună pe imagine */
}
/* BUTOANE PREMIUM - BUY TICKET / MORE INFO */
.hero-btn-primary, .hero-btn-secondary {
    font-size: 13px;
    font-weight: 900;
    padding: 12px 28px;
    border-radius: 6px;        /* păstrează forma originală */
    text-transform: uppercase;
    letter-spacing: 2px;
    text-decoration: none;     /* fără underline */
    transition: all 0.4s ease;
}

/* PRIMARY - Buy Ticket */
.hero-btn-primary {
    background: linear-gradient(135deg, #B20000, #8B0000);  /* roșu premium */
    color: white;
    box-shadow: 0 6px 15px rgba(178, 0, 0, 0.5);  /* glow subtil */
}

.hero-btn-primary:hover {
    background: linear-gradient(135deg, #CC0000, #990000);
    box-shadow: 0 8px 28px rgba(204, 0, 0, 0.7);
    transform: scale(1.08);
}

/* SECONDARY - More Info */
.hero-btn-secondary {
    background: transparent;
    border: 2px solid rgba(255,255,255,0.6);
    color: white;
    box-shadow: 0 4px 12px rgba(255, 255, 255, 0.1);
}

.hero-btn-secondary:hover {
    border-color: #B20000;
    color: #B20000;
    box-shadow: 0 6px 20px rgba(178,0,0,0.4);
    transform: scale(1.08);
}
 
/* Dots */
.hero-dots {
    position: absolute;
    bottom: 20px;
    left: 60px;
    display: flex;
    gap: 8px;
    z-index: 3;
}
.hero-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: rgba(255,255,255,0.25);
    border: none; cursor: pointer; padding: 0;
    transition: background 0.2s;
}
.hero-dot.active { background: white; }
 
/* Săgețe */
.hero-arrows {
    position: absolute;
    bottom: 12px;
    right: 30px;
    display: flex;
    gap: 8px;
    z-index: 3;
}
/* SAGETI PREV / NEXT */
.hero-arrow {
    width: 50px;        /* mai mari */
    height: 50px;
    font-size: 28px;    /* săgețile mai mari */
    border-radius: 50%; /* butoane perfect circulare */
