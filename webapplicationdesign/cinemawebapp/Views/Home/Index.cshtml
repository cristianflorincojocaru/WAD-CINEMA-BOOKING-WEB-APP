    border: 2px solid rgba(255,255,255,0.2);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
}

.hero-arrow:hover {
    background: rgba(255,255,255,0.15);
    border-color: #B20000; /* roșu mai închis la hover */
    color: #B20000;
    font-size: 36px; 
    transform: scale(1.1);
}
</style>
