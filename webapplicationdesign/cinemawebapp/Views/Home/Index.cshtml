@section Scripts {
<script>
    function initInfiniteSlider(sliderId, intervalMs) {
        const slider = document.getElementById(sliderId);
        const itemWidth = 220 + 16;
        let autoInterval;
        let currentIndex = 0;
        let isAnimating = false;

        const originals = Array.from(slider.children);
        const total = originals.length;

        originals.forEach(item => slider.appendChild(item.cloneNode(true)));
        originals.slice().reverse().forEach(item => slider.insertBefore(item.cloneNode(true), slider.firstChild));

        currentIndex = total;
        slider.style.transition = 'none';
        slider.style.transform = `translateX(-${currentIndex * itemWidth}px)`;

        function goTo(index, animate) {
            return new Promise(resolve => {
                slider.style.transition = animate ? 'transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94)' : 'none';
                slider.style.transform = `translateX(-${index * itemWidth}px)`;
                if (animate) {
                    slider.addEventListener('transitionend', function handler() {
                        slider.removeEventListener('transitionend', handler);
                        resolve();
                    });
                } else {
                    slider.getBoundingClientRect();
                    resolve();
                }
            });
        }

        async function next() {
            if (isAnimating) return;
            isAnimating = true;
            currentIndex++;
            await goTo(currentIndex, true);
            if (currentIndex >= total * 2) {
                currentIndex = total;
                await goTo(currentIndex, false);
            }
            isAnimating = false;
        }

        async function prev() {
            if (isAnimating) return;
            isAnimating = true;
            currentIndex--;
            await goTo(currentIndex, true);
            if (currentIndex < total) {
                currentIndex = total * 2 - 1;
                await goTo(currentIndex, false);
            }
            isAnimating = false;
        }

        function startAuto() { autoInterval = setInterval(next, intervalMs); }
        function stopAuto() { clearInterval(autoInterval); }

        startAuto();
        slider.addEventListener('mouseenter', stopAuto);
        slider.addEventListener('mouseleave', startAuto);
        document.getElementById(sliderId + '-prev').addEventListener('click', () => { stopAuto(); prev(); startAuto(); });
        document.getElementById(sliderId + '-next').addEventListener('click', () => { stopAuto(); next(); startAuto(); });
    }

    initInfiniteSlider('nowShowing', 3000);
    initInfiniteSlider('comingSoon', 4000);

    /* 🔥 HERO BANNER SCRIPT */
    (function() {
        const slides = document.querySelectorAll('.hero-slide');
        const dotsEl = document.getElementById('heroDots');

        if (!slides.length || !dotsEl) return;

        let cur = 0;
        let timer;

        slides.forEach((_, i) => {
            const d = document.createElement('button');
            d.className = 'hero-dot' + (i === 0 ? ' active' : '');
            d.onclick = () => goTo(i);
            dotsEl.appendChild(d);
        });

        function goTo(n) {
            slides[cur].classList.remove('active');
            dotsEl.children[cur].classList.remove('active');

            cur = (n + slides.length) % slides.length;

            slides[cur].classList.add('active');
            dotsEl.children[cur].classList.add('active');
        }

        window.heroNext = () => goTo(cur + 1);
        window.heroPrev = () => goTo(cur - 1);

        function start() {
            timer = setInterval(() => goTo(cur + 1), 5000);
        }

        function stop() {
            clearInterval(timer);
        }

        start();

        const banner = document.getElementById('heroBanner');
        if (banner) {
            banner.addEventListener('mouseenter', stop);
            banner.addEventListener('mouseleave', start);
        }
    })();
</script>
}}