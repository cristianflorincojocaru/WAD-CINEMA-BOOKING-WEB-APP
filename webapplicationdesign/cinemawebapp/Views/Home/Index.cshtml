@{
    ViewData["Title"] = "Home";
}
@model IEnumerable<cinemawebapp.Models.Movie>
@section Styles {
<style>
    /* CARDS */
    .movie-card {
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
        background-color: #141414;
        border: 1px solid #1e1e1e;
        border-radius: 10px;
        overflow: hidden;
    }
    .movie-card:hover {
        transform: scale(1.03);
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.8);
        border-color: #8B1A1A;
    }
    .movie-card .card-body {
        padding: 12px 14px;
        background-color: #141414;
    }
    .movie-card .card-title {
        font-size: 13px;
        font-weight: bold;
        color: white;
        letter-spacing: 1px;
        margin-bottom: 0;
    }
    .movie-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: all 0.35s ease;
}
    .movie-card:hover img {
        filter: brightness(0.35);
    }

    /* HOVER OVERLAY */
    .movie-img-wrapper {
    position: relative;
    overflow: hidden;
    height: 300px;  /* controlează dimensiunea */
}
    .movie-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 14px;
        opacity: 0;
        transition: opacity 0.35s ease;
        pointer-events: none;
    }
    .movie-card:hover .movie-overlay {
        opacity: 1;
    }
    .movie-card .card-body {
    padding: 12px 14px;
    background-color: #141414;
    border: 1px solid #1e1e1e;          /* border subtil gri */
    border-top-left-radius: 0;           /* colțul stânga sus drept */
    border-top-right-radius: 0;          /* colțul dreapta sus drept */
    border-bottom-left-radius: 8px;      /* colțul stânga jos rotunjit */
    border-bottom-right-radius: 8px;     /* colțul dreapta jos rotunjit */
    outline: none;                        /* elimină outline-ul implicit */
}
    .age-badge {
        position: absolute;
        top: 10px;
        right: 10px;
        background-color: #8B1A1A;
        color: white;
        font-size: 12px;
        font-weight: 700;
        padding: 3px 7px;
        border-radius: 4px;
        letter-spacing: 1px;
        text-transform: uppercase;
    }
    .overlay-title {
        font-size: 15px;
        font-weight: 700;
        color: white;
        text-align: center;
        letter-spacing: 1px;
        text-transform: uppercase;
        margin-bottom: 8px;
        line-height: 1.3;
    }
    .overlay-genres {
        font-size: 13px;
        color: #ccc;
        text-transform: uppercase;
        letter-spacing: 2px;
        text-align: center;
        margin-bottom: 6px;
    }
    .overlay-duration {
        font-size: 12px;
        color: #999;
        letter-spacing: 2px;
        text-transform: uppercase;
    }

    /* SLIDER */
    .slider-wrapper {
        position: relative;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .slider-viewport {
        overflow: hidden;
        flex: 1;
    }
    .movie-slider {
        display: flex;
        gap: 16px;
        padding: 10px 4px;
        transition: transform 0.5s ease;
        will-change: transform;
    }
    .movie-slider .slide-item {
        min-width: 220px;
        max-width: 220px;
        flex-shrink: 0;
    }
    .slider-btn {
        background: none;
        border: none;
        color: #333;
        font-size: 52px;
        cursor: pointer;
        z-index: 10;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        line-height: 1;
        padding: 0 8px;
        transition: color 0.2s, text-shadow 0.2s;
    }
    .slider-btn:hover {
        color: #cc2222;
        text-shadow: 0 0 18px rgba(139, 26, 26, 0.85), 0 0 35px rgba(139, 26, 26, 0.4);
    }

    /* SECTION HEADERS */
    .section-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 24px;
    }
    .section-header h2 {
        font-size: 12px;
        font-weight: bold;
        letter-spacing: 4px;
        text-transform: uppercase;
        color: white;
        margin: 0;
        white-space: nowrap;
    }
    .section-header-line {
        flex: 1;
        height: 1px;
        background: linear-gradient(to right, #2a2a2a, transparent);
    }

    /* PROMO CARDS */
    /* 🔥 PROMO CARDS UPDATED */
.promo-card {
    cursor: pointer;
    background-color: #0f0f0f;           /* mai întunecat */
    border: 2px solid #1e1e1e;          /* border inițial subtil */
    border-radius: 12px;                  /* colțuri uniforme */
    overflow: hidden;
    transition: all 0.35s cubic-bezier(0.25, 0.8, 0.25, 1); /* mai smooth */
    box-shadow: 0 2px 8px rgba(0,0,0,0.2); /* umbră subtilă */
}

.promo-card:hover {
    transform: scale(1.05);              /* zoom mai pronunțat la hover */
    border-color: #8B1A1A;               /* outline roșu */
    box-shadow: 0 12px 24px rgba(139,26,26,0.35); /* glow subtil roșu */
}

.promo-card:focus {
    outline: 2px solid #8B1A1A;          /* outline vizibil la focus */
    outline-offset: -2px;                 /* urmează conturul cardului */
}

.promo-card h6 {
    font-size: 12px;
    letter-spacing: 2px;
    color: white;
    transition: color 0.3s, transform 0.3s;
}

.promo-card:hover h6 {
    color: #ff4444;                       /* highlight text la hover */
    transform: translateY(-2px);          /* efect subtil de mișcare */
}

.promo-card .card-body {
    padding: 20px 12px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border-radius: inherit;               /* outline-ul urmează colțurile */
    background-color: inherit;            /* păstrează fundalul uniform */
}

    /* SECTION DIVIDER */
    .section-divider {
        height: 1px;
        background: linear-gradient(to right, transparent, #1e1e1e, transparent);
        border: none;
        margin: 50px 0;
    }

    #cinemaCarousel {
    max-width: 100%;       /* ocupă lățimea containerului */
    height: 350px;         /* înălțimea bannerului */
    overflow: hidden;      /* ascunde ce depășește */
    border-radius: 10px;   /* optional, colțuri rotunjite */
    position: relative;
}

#cinemaCarousel .carousel-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;     /* scalează imaginea și taie marginile */
    object-position: center center; /* partea vizibilă centrală */
    display: block;
    transition: transform 0.5s ease; /* zoom ușor */
}

/* optional: mic zoom cinematic pe imaginea activă */
#cinemaCarousel .carousel-item.active img {
    transform: scale(1.05);
}

#cinemaCarousel .carousel-item::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.25); /* semi-transparent negru */
}

.banner-slide {
    display: flex;
    height: 350px;             /* înălțime cinematică */
    border-radius: 12px;
    overflow: hidden;
    position: relative;
}

/* Partea stângă – text + fade */
.banner-text {
    flex: 0 0 35%; /* text mai îngust, ~35% din lățime */
    padding: 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    color: white;
    position: relative;
}

/* Gradient real pentru fade peste imagine */
.banner-text::after {
    content: "";
    position: absolute;
    top: 0;
    right: -50px; /* suprapunere peste imagine */
    width: 100px;  /* cât de lung e fade-ul */
    height: 100%;
    background: linear-gradient(to right, rgba(20,20,20,1), rgba(20,20,20,0));
    pointer-events: none;
}

.banner-text h2 {
    font-size: 28px;
    font-weight: bold;
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 2px;
}

.banner-text p {
    font-size: 14px;
    line-height: 1.5;
    color: #ccc;
}

/* Partea dreaptă – imagine cropată */
.banner-img {
    flex: 1;
    overflow: hidden;
    position: relative;
}

.banner-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.5s ease;
}

.banner-slide:hover .banner-img img {
    transform: scale(1.05); /* zoom cinematic la hover */
}


