@model IEnumerable<cinemawebapp.Models.Movie>

@{
    ViewData["Title"] = "Movies";
}

@section Styles {
<style>
    .movie-card {
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
        background-color: #141414;
        border: 1px solid #1e1e1e;
        border-radius: 10px;
        overflow: hidden;
    }

    .movie-card:hover {
        transform: scale(1.03);
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.8);
        border-color: #8B1A1A;
    }

    .movie-card .card-body {
        padding: 12px 14px;
        background-color: #141414;
        border: 1px solid #1e1e1e;
        border-top-left-radius: 0;
        border-top-right-radius: 0;
        border-bottom-left-radius: 8px;
        border-bottom-right-radius: 8px;
        outline: none;
    }

    .movie-card .card-title {
        font-size: 14px;
        font-weight: bold;
        color: white;
        letter-spacing: 1px;
        margin-bottom: 4px;
    }

    .movie-card .card-text {
        font-size: 11px;
        color: #666;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 0;
    }

    .movie-img-wrapper {
    position: relative;
    overflow: hidden;
    /* sterge: height: 360px; */
}

    .movie-img-wrapper img {
    width: 100%;
    height: auto; /* <-- in loc de height: 100% */
    object-fit: unset;
    object-position: unset;
    display: block;
    transition: all 0.35s ease;
}

    .movie-card:hover img {
        transform: scale(1.1);
        filter: brightness(0.35);
    }

    .movie-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 14px;
        opacity: 0;
        transition: opacity 0.35s ease;
        pointer-events: none;
    }

    .movie-card:hover .movie-overlay {
        opacity: 1;
    }

    .age-badge {
        position: absolute;
        top: 10px;
        right: 10px;
        background-color: #8B1A1A;
        color: white;
        font-size: 12px;
        font-weight: 700;
        padding: 3px 7px;
        border-radius: 4px;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .overlay-title {
        font-size: 15px;
        font-weight: 700;
        color: white;
        text-align: center;
        letter-spacing: 1px;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .overlay-genres {
        font-size: 13px;
        color: #ccc;
        text-transform: uppercase;
        letter-spacing: 2px;
        text-align: center;
        margin-bottom: 6px;
    }

    .overlay-duration {
        font-size: 12px;
        color: #999;
        letter-spacing: 2px;
        text-transform: uppercase;
    }

    .tab-btn {
        position: relative;
        display: inline-block;
        padding: 12px 44px;
        font-size: 11px;
        font-weight: 900;
        letter-spacing: 3px;
        text-transform: uppercase;
        text-decoration: none;
        border-radius: 6px;
        border: 1px solid #2a2a2a;
        color: #666;
        background: #0a0a0a;
        overflow: hidden;
        transition: color 0.35s ease, border-color 0.35s ease, transform 0.3s ease;
    }

    .tab-btn::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, #B20000, #7a0000);
        transform: translateX(-101%);
        transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        z-index: 0;
    }

    .tab-btn span {
        position: relative;
        z-index: 1;
    }

    .tab-btn:hover {
        color: white;
        border-color: #B20000;
        transform: translateY(-2px);
    }

    .tab-btn:hover::before {
        transform: translateX(0);
    }

    .tab-btn.active-tab {
        color: white;
        border-color: transparent;
        box-shadow: 0 4px 20px rgba(178,0,0,0.45);
        border-bottom: 2px solid #ff3333;
    }

    .tab-btn.active-tab::before {
        transform: translateX(0);
    }

    .btn-manage {
    position: relative;
    background: linear-gradient(135deg, #B20000, #8B0000);
    border: none;
    color: white;
    font-weight: 900;
    letter-spacing: 3px;
    padding: 8px 22px;
    font-size: 11px;
    border-radius: 6px;
    text-transform: uppercase;
    text-decoration: none;
    box-shadow: 0 6px 15px rgba(178,0,0,0.5);
    transition: all 0.4s ease;
    display: inline-block;
}
.btn-manage:hover {
    background: linear-gradient(135deg, #CC0000, #990000);
    box-shadow: 0 8px 28px rgba(204,0,0,0.7);
    transform: scale(1.05);
    color: white;
}
    .section-divider {
        height: 1px;
        background: linear-gradient(to right, transparent, #2a2a2a, transparent);
        border: none;
        margin: 0 0 40px 0;
    }
</style>
}

<div class="container mt-5 mb-5">

    <h1 class="mb-2 fw-bold text-uppercase text-center" style="letter-spacing:4px;">Movies</h1>
    <p class="text-center mb-4" style="color:#aaa; font-size:12px; letter-spacing:3px; text-transform:uppercase;">
        Weekly curated programme
    </p>

    <div class="text-end mb-3">
       @if (User.IsInRole("Admin"))
{
    <a href="/Movies" class="btn-manage">⚙ Manage</a>
}
    </div>

    <div class="d-flex justify-content-center gap-3 mb-4">
        <a href="/Home/Movies" class="tab-btn active-tab"><span>Now in Theaters</span></a>
        <a href="/Home/Upcoming" class="tab-btn"><span>Coming Soon</span></a>
    </div>

    <hr class="section-divider">

    <div class="row g-4">
        @foreach (var movie in Model)
        {
            <div class="col-md-3">
                <a href="/Home/MovieDetails/@movie.Id" class="text-decoration-none">
                    <div class="card movie-card">
                        <div class="movie-img-wrapper">
                            <img src="@movie.ImagePath" alt="@movie.Title">
                            <div class="movie-overlay">
                                <span class="age-badge">@movie.AgeRating</span>
                                <div class="overlay-title">@movie.Title</div>
                                <div class="overlay-genres">@movie.Genre</div>
                                <div class="overlay-duration">@movie.DurationMinutes min</div>
                            </div>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">@movie.Title</h5>
                            <p class="card-text">@movie.Genre</p>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</div>
