@model cinemawebapp.Models.Promotion

@{
    ViewData["Title"] = "Promotion Details";
}

@section Styles {
    <style>
        .promo-detail-card {
            background-color: #0f0f0f;
            border: 1px solid #1e1e1e;
            border-top: 2px solid #8B1A1A;
            border-radius: 0 0 12px 12px;
            max-width: 700px;
            margin: 0 auto;
        }
        .promo-detail-body {
            padding: 50px 60px;
            text-align: center;
        }
        .promo-detail-title {
            font-size: 13px;
            font-weight: bold;
            letter-spacing: 4px;
            text-transform: uppercase;
            color: white;
            margin-bottom: 12px;
        }
        .promo-detail-divider {
            width: 40px;
            height: 1px;
            background-color: #8B1A1A;
            margin: 0 auto 30px auto;
        }
        .promo-detail-text {
            font-size: 14px;
            color: #aaa;
            line-height: 2;
            letter-spacing: 0.5px;
            margin-bottom: 10px;
        }
        .promo-detail-note {
            font-size: 11px;
            color: #aaa;
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-top: 20px;
            margin-bottom: 0;
        }
        .btn-tickets {
            display: inline-block;
            margin-top: 36px;
            padding: 14px 50px;
            background-color: #8B1A1A;
            color: white;
            font-size: 11px;
            font-weight: bold;
            letter-spacing: 4px;
            text-transform: uppercase;
            text-decoration: none;
            border-radius: 6px;
            border: none;
            transition: background-color 0.2s;
        }
        .btn-tickets:hover { background-color: #6e1414; color: white; }
        .btn-back {
            display: inline-block;
            margin-top: 24px;
            padding: 10px 30px;
            background-color: transparent;
            color: #555;
            font-size: 11px;
            font-weight: bold;
            letter-spacing: 3px;
            text-transform: uppercase;
            text-decoration: none;
            border: 1px solid #2a2a2a;
            border-radius: 6px;
            transition: all 0.2s;
        }
        .btn-back:hover { border-color: #8B1A1A; color: #8B1A1A; }
        .section-divider {
            height: 1px;
            background: linear-gradient(to right, transparent, #2a2a2a, transparent);
            border: none;
            margin: 0 0 50px 0;
        }
        .discount-badge {
            display: inline-block;
            background-color: #8B1A1A;
            color: white;
            font-size: 13px;
            font-weight: bold;
            letter-spacing: 2px;
            padding: 6px 18px;
            border-radius: 20px;
            margin-bottom: 20px;
        }
    </style>
}

<div class="container mt-5 mb-5">

    <h1 class="mb-2 fw-bold text-uppercase text-center" style="letter-spacing:4px;">Promotion Details</h1>
    <p class="text-center mb-5" style="color:#aaa; font-size:12px; letter-spacing:3px; text-transform:uppercase;">The Film Vault — Special Offers</p>

    <hr class="section-divider">

    <div class="promo-detail-card">
        <div class="promo-detail-body">

            <div style="font-size:36px; margin-bottom:20px;">@Model.Emoji</div>

            <div class="promo-detail-title">@Model.Title</div>
            <div class="promo-detail-divider"></div>

            <div class="discount-badge">@Model.DiscountPercent% Discount</div>

            <p class="promo-detail-text">@Model.Description</p>
            <p class="promo-detail-text">
                Valid from @Model.ValidFrom.ToString("MMM dd, yyyy") to @Model.ValidUntil.ToString("MMM dd, yyyy").
            </p>
            <p class="promo-detail-note">Cannot be combined with other promotions.</p>

            <br>
            @if (Model.LinkedTicketType != null)
{
    <a href="/Home/Tickets?ticketType=@Uri.EscapeDataString(Model.LinkedTicketType)" class="btn-tickets">Buy Tickets</a>
}
else
{
    <a href="/Home/Tickets" class="btn-tickets">Buy Tickets</a>
}

        </div>
    </div>

    <div class="text-center mt-4">
        <a href="/Home/Promotions" class="btn-back">← Back to Promotions</a>
    </div>



</div>
