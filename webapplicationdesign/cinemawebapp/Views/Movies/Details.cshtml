@model cinemawebapp.Models.Movie

@{
    ViewData["Title"] = "Movie Details";
}

@section Styles {
<style>
    .page-header { text-align: center; padding: 60px 0 40px; }
    .page-header h1 { font-size: 36px; font-weight: 700; letter-spacing: 6px; text-transform: uppercase; color: white; margin-bottom: 8px; }
    .page-header p { font-size: 12px; letter-spacing: 4px; text-transform: uppercase; color: #aaa; }
    .details-card {
        background-color: #0f0f0f; border: 1px solid #1e1e1e;
        border-radius: 12px; padding: 40px; max-width: 760px; margin: 0 auto 60px;
    }
    .details-card::before { content: ''; display: block; height: 2px; background: #8B1A1A; border-radius: 2px 2px 0 0; margin: -40px -40px 40px; }
    .detail-item { margin-bottom: 24px; border-bottom: 1px solid #1a1a1a; padding-bottom: 24px; }
    .detail-item:last-of-type { border-bottom: none; }
    .detail-label { font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: #8B1A1A; font-weight: 700; margin-bottom: 8px; }
    .detail-value { font-size: 14px; color: #aaa; letter-spacing: 0.5px; }
    .btn-edit {
        background: linear-gradient(135deg, #B20000, #8B0000);
        color: white; font-size: 11px; font-weight: 700;
        letter-spacing: 3px; text-transform: uppercase;
        padding: 14px 36px; border-radius: 6px; text-decoration: none;
        display: inline-block; transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(178,0,0,0.4);
    }
    .btn-edit:hover { background: linear-gradient(135deg, #CC0000, #990000); color: white; transform: scale(1.05); }
    .btn-back {
        position: relative; overflow: hidden;
        background: transparent; border: 1px solid #2a2a2a; color: #aaa;
        font-size: 11px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase;
        padding: 14px 36px; border-radius: 6px; text-decoration: none;
        display: inline-block; transition: color 0.3s, border-color 0.3s;
    }
    .btn-back::before {
        content: ''; position: absolute; inset: 0;
        background: #1e1e1e; transform: scaleX(0); transform-origin: left;
        transition: transform 0.3s ease; z-index: 0;
    }
    .btn-back:hover::before { transform: scaleX(1); }
    .btn-back:hover { color: white; border-color: #3a3a3a; }
    .btn-back span { position: relative; z-index: 1; }
    .form-actions { display: flex; gap: 12px; align-items: center; margin-top: 10px; }
    .badge-upcoming { font-size: 9px; letter-spacing: 2px; text-transform: uppercase; padding: 4px 10px; border-radius: 4px; font-weight: 700; }
    .badge-now { background-color: #1a2a1a; color: #4caf50; }
    .badge-soon { background-color: #2a1a1a; color: #8B1A1A; }
</style>
}

<div class="container">
    <div class="page-header">
        <h1>Movie Details</h1>
        <p>Database — View Entry</p>
    </div>

    <div class="details-card">
        <div class="detail-item">
            <div class="detail-label">Title</div>
            <div class="detail-value">@Model.Title</div>
        </div>
        <div class="detail-item">
            <div class="detail-label">Director</div>
            <div class="detail-value">@Model.Director</div>
        </div>
        <div class="detail-item">
            <div class="detail-label">Genre</div>
            <div class="detail-value">@Model.Genre</div>
        </div>
        <div class="detail-item">
            <div class="detail-label">Duration</div>
            <div class="detail-value">@Model.DurationMinutes minutes</div>
        </div>
        <div class="detail-item">
            <div class="detail-label">Age Rating</div>
            <div class="detail-value">@Model.AgeRating</div>
        </div>
        <div class="detail-item">
            <div class="detail-label">Description</div>
            <div class="detail-value">@Html.Raw(Model.Description.Replace(Environment.NewLine, "<br/>"))</div>
        </div>
        <div class="detail-item">
            <div class="detail-label">Image Path</div>
            <div class="detail-value">@Model.ImagePath</div>
        </div>
        <div class="detail-item">
            <div class="detail-label">Trailer URL</div>
            <div class="detail-value">@Model.TrailerUrl</div>
        </div>
        <div class="detail-item">
            <div class="detail-label">Status</div>
            <div>
                @if (Model.IsUpcoming)
                {
                    <span class="badge-upcoming badge-soon">Coming Soon</span>
                }
                else
                {
                    <span class="badge-upcoming badge-now">Now Showing</span>
                }
            </div>
        </div>

        <div class="form-actions">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-edit">Edit</a>
            <a asp-action="Index" class="btn-back"><span>← Back</span></a>
        </div>
    </div>
</div>