@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityUser>

@{
    ViewData["Title"] = "Users";
}

<div class="container mt-5 mb-5">
    <h1 class="mb-2 fw-bold text-uppercase text-center" style="letter-spacing:4px;">Users</h1>
    <p class="text-center mb-4" style="color:#aaa; font-size:12px; letter-spacing:3px; text-transform:uppercase;">Admin — Manage Users</p>

    <div style="background-color:#0f0f0f; border-radius:12px; border:1px solid #1e1e1e; overflow:hidden;">
        <table style="width:100%; border-collapse:collapse;">
            <thead>
                <tr style="border-bottom:1px solid #8B1A1A;">
                    <th style="padding:14px 20px; font-size:10px; letter-spacing:3px; text-transform:uppercase; color:#8B1A1A;">Email</th>
                    <th style="padding:14px 20px; font-size:10px; letter-spacing:3px; text-transform:uppercase; color:#8B1A1A;">ID</th>
                    <th style="padding:14px 20px; font-size:10px; letter-spacing:3px; text-transform:uppercase; color:#8B1A1A;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr style="border-bottom:1px solid #1a1a1a;">
                        <td style="padding:14px 20px; color:white; font-size:13px;">@user.Email</td>
                        <td style="padding:14px 20px; color:#aaa; font-size:13px;">@user.Id</td>
                        <td style="padding:14px 20px;">
                            <form asp-action="Delete" asp-route-id="@user.Id" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" style="font-size:10px; font-weight:700; letter-spacing:2px; text-transform:uppercase; padding:4px 12px; border-radius:4px; border:1px solid #5a0000; color:#cc2222; background:transparent; cursor:pointer; transition:all 0.25s ease;"
                                        onmouseover="this.style.background='#8B1A1A';this.style.color='white';"
                                        onmouseout="this.style.background='transparent';this.style.color='#8B1A1A';">
                                    Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>