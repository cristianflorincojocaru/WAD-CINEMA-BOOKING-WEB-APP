@model cinemawebapp.Models.Cinema

@{
    ViewData["Title"] = "Edit Cinema";
}

@section Styles {
<style>
    .form-card {
        background-color: #0f0f0f;
        border: 1px solid #1e1e1e;
        border-top: 2px solid #8B1A1A;
        border-radius: 0 0 12px 12px;
        padding: 40px;
        box-shadow: 0 12px 40px rgba(0,0,0,0.4);
    }

    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
    .form-grid-full { margin-bottom: 16px; }

    .field-float {
        position: relative;
        background: #0c0c0c;
        border: 1px solid #222;
        border-radius: 10px;
        padding: 22px 20px 10px;
        transition: border-color 0.35s ease, box-shadow 0.35s ease;
        overflow: hidden;
    }

    .field-float::after {
        content: '';
        position: absolute;
        bottom: 0; left: 50%;
        height: 2px; width: 0;
        background: linear-gradient(to right, #7a0000, #ff3333, #7a0000);
        transform: translateX(-50%);
        transition: width 0.45s cubic-bezier(0.4, 0, 0.2, 1);
        border-radius: 2px;
    }

    .field-float:focus-within {
        border-color: #2a2a2a;
        box-shadow: 0 12px 40px rgba(178,0,0,0.1), 0 2px 12px rgba(0,0,0,0.5);
    }

    .field-float:focus-within::after { width: 100%; }

    .field-float label {
        position: absolute;
        top: 50%; left: 20px;
        transform: translateY(-50%);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: #aaa;
        pointer-events: none;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .field-float:focus-within label,
    .field-float.has-value label {
        top: 14px;
        transform: translateY(0);
        font-size: 8px;
        letter-spacing: 4px;
        color: #8B1A1A;
    }

    .field-float input {
        background: transparent !important;
        color: white !important;
        border: none !important;
        outline: none !important;
        box-shadow: none !important;
        width: 100%;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 1px;
        padding: 0;
        margin-top: 4px;
    }

    .val-error {
        display: block;
        font-size: 9px;
        letter-spacing: 2px;
        color: #cc2222;
        margin-top: 4px;
        text-transform: uppercase;
    }

    .btn-save {
        position: relative;
        background: linear-gradient(135deg, #B20000, #8B0000);
        border: none;
        color: white;
        font-weight: 900;
        letter-spacing: 3px;
        padding: 12px 40px;
        font-size: 11px;
        border-radius: 6px;
        text-transform: uppercase;
        box-shadow: 0 6px 15px rgba(178,0,0,0.5);
        transition: all 0.4s ease;
        cursor: pointer;
    }

    .btn-save:hover {
        background: linear-gradient(135deg, #CC0000, #990000);
        box-shadow: 0 8px 28px rgba(204,0,0,0.7);
        transform: scale(1.05);
        color: white;
    }

    .btn-back {
        position: relative;
        background: transparent;
        border: 2px solid #2a2a2a;
        color: #555;
        font-weight: 900;
        font-size: 10px;
        letter-spacing: 3px;
        text-transform: uppercase;
        padding: 12px 28px;
        border-radius: 6px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        overflow: hidden;
        transition: color 0.35s ease, border-color 0.35s ease, transform 0.3s ease;
    }

    .btn-back::before {
        content: '';
        position: absolute;
        inset: 0;
        background: #1a1a1a;
        transform: translateX(-101%);
        transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        z-index: 0;
    }

    .btn-back span { position: relative; z-index: 1; }

    .btn-back:hover {
        color: #aaa;
        border-color: #3a3a3a;
        transform: translateY(-2px);
    }

    .btn-back:hover::before { transform: translateX(0); }

    .section-divider {
        height: 1px;
        background: linear-gradient(to right, transparent, #2a2a2a, transparent);
        border: none;
        margin: 0 0 40px 0;
    }
</style>
}

<div class="container mt-5 mb-5" style="max-width:700px;">

    <h1 class="mb-2 fw-bold text-uppercase text-center" style="letter-spacing:4px;">Edit Cinema</h1>
    <p class="text-center mb-5" style="color:#aaa; font-size:12px; letter-spacing:3px; text-transform:uppercase;">Update Database Record</p>

    <hr class="section-divider">

    <div class="form-card">
        <form asp-action="Edit">
            <input asp-for="Id" type="hidden" />

            <div class="form-grid">
                <div class="field-float has-value" id="ff-name">
                    <label>Name</label>
                    <input asp-for="Name" autocomplete="off"
                           oninput="toggleVal('ff-name', this)">
                    <span asp-validation-for="Name" class="val-error"></span>
                </div>
                <div class="field-float has-value" id="ff-city">
                    <label>City</label>
                    <input asp-for="City" autocomplete="off"
                           oninput="toggleVal('ff-city', this)">
                    <span asp-validation-for="City" class="val-error"></span>
                </div>
            </div>

            <div class="form-grid-full">
                <div class="field-float has-value" id="ff-address">
                    <label>Address</label>
                    <input asp-for="Address" autocomplete="off"
                           oninput="toggleVal('ff-address', this)">
                </div>
            </div>

            <div class="form-grid">
                <div class="field-float has-value" id="ff-hours">
                    <label>Opening Hours</label>
                    <input asp-for="OpeningHours" autocomplete="off"
                           oninput="toggleVal('ff-hours', this)">
                </div>
                <div class="field-float has-value" id="ff-contact">
                    <label>Contact</label>
                    <input asp-for="Contact" autocomplete="off"
                           oninput="toggleVal('ff-contact', this)">
                </div>
            </div>

            <div class="form-grid-full mt-2">
                <div class="field-float has-value" id="ff-image">
                    <label>Image Path</label>
                    <input asp-for="ImagePath" autocomplete="off"
                           oninput="toggleVal('ff-image', this)">
                </div>
            </div>

            <div class="d-flex gap-3 mt-4">
                <button type="submit" class="btn-save">Save Changes</button>
                <a href="/Cinemas" class="btn-back"><span>← Back</span></a>
            </div>

        </form>
    </div>
</div>

@section Scripts {
<script>
    function toggleVal(id, el) {
        const block = document.getElementById(id);
        if (el.value.trim()) block.classList.add('has-value');
        else block.classList.remove('has-value');
    }
</script>
}