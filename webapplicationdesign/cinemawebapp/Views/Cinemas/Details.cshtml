@model cinemawebapp.Models.Cinema

@{
    ViewData["Title"] = "Cinema Details";
}

@section Styles {
    <style>
        .detail-card {
            background-color: #0f0f0f;
            border: 1px solid #1e1e1e;
            border-top: 2px solid #8B1A1A;
            border-radius: 0 0 12px 12px;
            padding: 40px;
            box-shadow: 0 12px 40px rgba(0,0,0,0.4);
        }

        .detail-row {
            display: flex;
            flex-direction: column;
            padding: 18px 0;
            border-bottom: 1px solid #141414;
            gap: 6px;
        }

            .detail-row:last-of-type {
                border-bottom: none;
            }

        .detail-label {
            font-size: 8px;
            letter-spacing: 4px;
            text-transform: uppercase;
            color: #8B1A1A;
            font-weight: 900;
        }

        .detail-value {
            font-size: 14px;
            color: #ccc;
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        .btn-edit {
            position: relative;
            background: linear-gradient(135deg, #B20000, #8B0000);
            border: none;
            color: white;
            font-weight: 900;
            letter-spacing: 3px;
            padding: 12px 40px;
            font-size: 11px;
            border-radius: 6px;
            text-transform: uppercase;
            text-decoration: none;
            box-shadow: 0 6px 15px rgba(178,0,0,0.5);
            transition: all 0.4s ease;
            display: inline-block;
        }

            .btn-edit:hover {
                background: linear-gradient(135deg, #CC0000, #990000);
                box-shadow: 0 8px 28px rgba(204,0,0,0.7);
                transform: scale(1.05);
                color: white;
            }

        .btn-back {
            position: relative;
            background: transparent;
            border: 2px solid #2a2a2a;
            color: #777;
            font-weight: 900;
            font-size: 10px;
            letter-spacing: 3px;
            text-transform: uppercase;
            padding: 12px 28px;
            border-radius: 6px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            overflow: hidden;
            transition: color 0.35s ease, border-color 0.35s ease, transform 0.3s ease;
        }

            .btn-back::before {
                content: '';
                position: absolute;
                inset: 0;
                background: #1a1a1a;
                transform: translateX(-101%);
                transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
                z-index: 0;
            }

            .btn-back span {
                position: relative;
                z-index: 1;
            }

            .btn-back:hover {
                color: #aaa;
                border-color: #3a3a3a;
                transform: translateY(-2px);
            }

                .btn-back:hover::before {
                    transform: translateX(0);
                }

        .section-divider {
            height: 1px;
            background: linear-gradient(to right, transparent, #2a2a2a, transparent);
            border: none;
            margin: 0 0 40px 0;
        }
    </style>
}

<div class="container mt-5 mb-5" style="max-width:700px;">

    <h1 class="mb-2 fw-bold text-uppercase text-center" style="letter-spacing:4px;">Cinema Details</h1>
    <p class="text-center mb-5" style="color:#aaa; font-size:12px; letter-spacing:3px; text-transform:uppercase;">Database Record</p>

    <hr class="section-divider">

    <div class="detail-card">

        <div class="detail-row">
            <span class="detail-label">Name</span>
            <span class="detail-value">@Model.Name</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">City</span>
            <span class="detail-value">@Model.City</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Address</span>
            <span class="detail-value">@Model.Address</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Opening Hours</span>
            <span class="detail-value">@Model.OpeningHours</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Contact</span>
            <span class="detail-value">@Model.Contact</span>
        </div>

        <div class="d-flex gap-3 mt-4">
            <a href="/Cinemas/Edit/@Model.Id" class="btn-edit">Edit</a>
            <a href="/Cinemas" class="btn-back"><span>← Back</span></a>
        </div>

    </div>
</div>