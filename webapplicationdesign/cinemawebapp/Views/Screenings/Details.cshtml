@model cinemawebapp.Models.Screening

@{
    ViewData["Title"] = "Screening Details";
    var ticketsSold = ViewBag.TicketsSold as int? ?? 0;
}

@section Styles {
<style>
    .page-header { text-align: center; padding: 60px 0 40px; }
    .page-header h1 { font-size: 36px; font-weight: 700; letter-spacing: 6px; text-transform: uppercase; color: white; margin-bottom: 8px; }
    .page-header p { font-size: 12px; letter-spacing: 4px; text-transform: uppercase; color: #aaa; }
    .details-card {
        background-color: #0f0f0f; border: 1px solid #1e1e1e;
        border-radius: 12px; padding: 40px; max-width: 760px; margin: 0 auto 60px;
    }
    .details-card::before { content: ''; display: block; height: 2px; background: #8B1A1A; border-radius: 2px 2px 0 0; margin: -40px -40px 40px; }
    .detail-item { margin-bottom: 24px; border-bottom: 1px solid #1a1a1a; padding-bottom: 24px; }
    .detail-item:last-of-type { border-bottom: none; }
    .detail-label { font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: #8B1A1A; font-weight: 700; margin-bottom: 8px; }
    .detail-value { font-size: 14px; color: white; }
    .detail-value.muted { color: #aaa; }

    .capacity-bar-wrap { margin-top: 8px; background: #1a1a1a; border-radius: 4px; height: 6px; overflow: hidden; }
    .capacity-bar { height: 100%; background: linear-gradient(to right, #B20000, #ff3333); border-radius: 4px; transition: width 0.6s ease; }

    .btn-edit {
        background: linear-gradient(135deg, #B20000, #8B0000);
        color: white; font-size: 11px; font-weight: 700;
        letter-spacing: 3px; text-transform: uppercase;
        padding: 14px 36px; border-radius: 6px; text-decoration: none;
        display: inline-block; transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(178,0,0,0.4); text-align: center;
    }
    .btn-edit:hover { background: linear-gradient(135deg, #CC0000, #990000); color: white; transform: scale(1.05); }
    .btn-buy {
        background: transparent; border: 1px solid #1a3a1a; color: #4caf50;
        font-size: 11px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase;
        padding: 14px 36px; border-radius: 6px; text-decoration: none;
        display: inline-block; transition: all 0.2s ease; text-align: center;
    }
    .btn-buy:hover { background-color: #1a3a1a; color: white; }
    .btn-back {
        position: relative; overflow: hidden;
        background: transparent; border: 1px solid #2a2a2a; color: #aaa;
        font-size: 11px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase;
        padding: 14px 36px; border-radius: 6px; text-decoration: none;
        display: inline-block; transition: color 0.3s, border-color 0.3s; text-align: center;
    }
    .btn-back::before { content: ''; position: absolute; inset: 0; background: #1e1e1e; transform: scaleX(0); transform-origin: left; transition: transform 0.3s ease; z-index: 0; }
    .btn-back:hover::before { transform: scaleX(1); }
    .btn-back:hover { color: white; border-color: #3a3a3a; }
    .btn-back span { position: relative; z-index: 1; }
    .form-actions { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; margin-top: 10px; }
</style>
}

<div class="container">
    <div class="page-header">
        <h1>Screening Details</h1>
        <p>Database — View Entry</p>
    </div>

    <div class="details-card">
        <div class="detail-item">
            <div class="detail-label">Movie</div>
            <div class="detail-value">@Model.Movie.Title</div>
        </div>
        <div class="detail-item">
            <div class="detail-label">Cinema</div>
            <div class="detail-value muted">@Model.Hall.Cinema.Name</div>
        </div>
        <div class="detail-item">
            <div class="detail-label">Hall</div>
            <div class="detail-value muted">@Model.Hall.Name — Capacity: @Model.Hall.Capacity</div>
        </div>
        <div class="detail-item">
            <div class="detail-label">Date</div>
            <div class="detail-value muted">@Model.StartTime.ToString("dddd, dd MMMM yyyy")</div>
        </div>
        <div class="detail-item">
            <div class="detail-label">Time</div>
            <div class="detail-value muted">@Model.StartTime.ToString("HH:mm")</div>
        </div>
        <div class="detail-item">
            <div class="detail-label">Tickets Sold</div>
            <div class="detail-value muted">@ticketsSold / @Model.Hall.Capacity</div>
            @{
                var pct = Model.Hall.Capacity > 0
                    ? (int)Math.Round((double)ticketsSold / Model.Hall.Capacity * 100)
                    : 0;
            }
            <div class="capacity-bar-wrap mt-2">
                <div class="capacity-bar" style="width:@pct%"></div>
            </div>
        </div>

        <div class="form-actions">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-edit">Edit</a>
            <a href="/Home/Tickets?screeningId=@Model.Id" class="btn-buy">Buy Ticket</a>
            <a asp-action="Index" class="btn-back"><span>← Back</span></a>
        </div>
    </div>
</div>
