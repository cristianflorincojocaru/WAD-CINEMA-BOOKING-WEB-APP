@model cinemawebapp.Models.Screening

@{
    ViewData["Title"] = "Add Screening";
}

@section Styles {
<style>
    .page-header { text-align: center; padding: 60px 0 40px; }
    .page-header h1 { font-size: 36px; font-weight: 700; letter-spacing: 6px; text-transform: uppercase; color: white; margin-bottom: 8px; }
    .page-header p { font-size: 12px; letter-spacing: 4px; text-transform: uppercase; color: #aaa; }
    .form-card {
        background-color: #0f0f0f; border: 1px solid #1e1e1e;
        border-radius: 12px; padding: 40px; max-width: 760px; margin: 0 auto 60px;
    }
    .form-card::before { content: ''; display: block; height: 2px; background: #8B1A1A; border-radius: 2px 2px 0 0; margin: -40px -40px 40px; }
    .form-row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .field-group { position: relative; margin-bottom: 20px; }
    .field-group label { display: block; font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: #8B1A1A; font-weight: 700; margin-bottom: 8px; }
    .field-group input, .field-group select {
        width: 100%; background-color: #141414; border: 1px solid #2a2a2a;
        border-radius: 6px; color: white; font-size: 13px; padding: 12px 16px;
        letter-spacing: 0.5px; transition: border-color 0.2s; font-family: inherit;
    }
    .field-group input:focus, .field-group select:focus { outline: none; border-color: #8B1A1A; }
    .field-group select option { background-color: #141414; }
    .field-group .text-danger { font-size: 11px; color: #cc2222; margin-top: 4px; display: block; }
    .error-box { background-color: #1a0000; border: 1px solid #5a0000; border-radius: 6px; padding: 12px 16px; margin-bottom: 20px; font-size: 12px; color: #cc2222; letter-spacing: 1px; }
    .btn-save {
        background: linear-gradient(135deg, #B20000, #8B0000);
        color: white; font-size: 11px; font-weight: 700;
        letter-spacing: 3px; text-transform: uppercase;
        padding: 14px 36px; border-radius: 6px; border: none; cursor: pointer;
        transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(178,0,0,0.4);
    }
    .btn-save:hover { background: linear-gradient(135deg, #CC0000, #990000); transform: scale(1.05); }
    .btn-back {
        position: relative; overflow: hidden;
        background: transparent; border: 1px solid #2a2a2a; color: #aaa;
        font-size: 11px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase;
        padding: 14px 36px; border-radius: 6px; text-decoration: none;
        display: inline-block; transition: color 0.3s, border-color 0.3s;
    }
    .btn-back::before { content: ''; position: absolute; inset: 0; background: #1e1e1e; transform: scaleX(0); transform-origin: left; transition: transform 0.3s ease; z-index: 0; }
    .btn-back:hover::before { transform: scaleX(1); }
    .btn-back:hover { color: white; border-color: #3a3a3a; }
    .btn-back span { position: relative; z-index: 1; }
    .form-actions { display: flex; gap: 12px; align-items: center; margin-top: 10px; }
</style>
}

<div class="container">
    <div class="page-header">
        <h1>Add Screening</h1>
        <p>Database — New Entry</p>
    </div>

    <div class="form-card">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="error-box"></div>

            <div class="form-row-2">
                <div class="field-group">
                    <label asp-for="MovieId">Movie</label>
                    <select asp-for="MovieId" asp-items="ViewBag.Movies"></select>
                    <span asp-validation-for="MovieId" class="text-danger"></span>
                </div>
                <div class="field-group">
                    <label asp-for="HallId">Hall</label>
                    <select asp-for="HallId" asp-items="ViewBag.Halls"></select>
                    <span asp-validation-for="HallId" class="text-danger"></span>
                </div>
            </div>

            <div class="field-group">
                <label asp-for="StartTime">Start Time</label>
                <input asp-for="StartTime" type="datetime-local" />
                <span asp-validation-for="StartTime" class="text-danger"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-save">Save Screening</button>
                <a asp-action="Index" class="btn-back"><span>← Back</span></a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
