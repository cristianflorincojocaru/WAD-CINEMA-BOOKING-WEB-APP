@model cinemawebapp.Models.TicketType
@{ ViewData["Title"] = "Edit Ticket Type"; }

@section Styles {
<style>
    .page-header { text-align: center; padding: 60px 0 40px; }
    .page-header h1 { font-size: 36px; font-weight: 700; letter-spacing: 6px; text-transform: uppercase; color: white; margin-bottom: 8px; }
    .page-header p { font-size: 11px; letter-spacing: 4px; text-transform: uppercase; color: #aaa; }
    .section-divider { height: 1px; background: linear-gradient(to right, transparent, #2a2a2a, transparent); border: none; margin: 0 0 40px 0; }
    .form-card { background: #0c0c0c; border: 1px solid #1e1e1e; border-radius: 14px; padding: 40px; max-width: 680px; margin: 0 auto; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
    .field-float { position: relative; background: #141414; border: 1px solid #222; border-radius: 10px; padding: 22px 20px 10px; transition: border-color 0.35s, box-shadow 0.35s; overflow: hidden; }
    .field-float::after { content: ''; position: absolute; bottom: 0; left: 50%; height: 2px; width: 0; background: linear-gradient(to right, #7a0000, #ff3333, #7a0000); transform: translateX(-50%); transition: width 0.45s cubic-bezier(0.4,0,0.2,1); border-radius: 2px; }
    .field-float:focus-within { border-color: #2a2a2a; box-shadow: 0 8px 30px rgba(178,0,0,0.1); }
    .field-float:focus-within::after { width: 100%; }
    .field-float label { position: absolute; top: 50%; left: 20px; transform: translateY(-50%); font-size: 11px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: #555; pointer-events: none; transition: all 0.3s cubic-bezier(0.4,0,0.2,1); margin: 0; }
    .field-float:focus-within label, .field-float.has-value label { top: 13px; transform: translateY(0); font-size: 8px; letter-spacing: 4px; color: #8B1A1A; }
    .field-float input, .field-float select { background: transparent !important; color: white !important; border: none !important; outline: none !important; box-shadow: none !important; width: 100%; font-size: 13px; font-weight: 600; letter-spacing: 1px; padding: 0; margin-top: 4px; font-family: inherit; }
    .field-float select option { background: #141414; }
    .field-check { display: flex; align-items: center; gap: 14px; background: #141414; border: 1px solid #222; border-radius: 10px; padding: 16px 20px; margin-bottom: 16px; cursor: pointer; }
    .field-check input[type="checkbox"] { width: 18px; height: 18px; accent-color: #B20000; cursor: pointer; flex-shrink: 0; }
    .field-check span { font-size: 11px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: #aaa; }
    .btn-save { background: linear-gradient(135deg, #B20000, #8B0000); border: none; color: white; font-weight: 900; letter-spacing: 3px; padding: 14px 36px; font-size: 12px; border-radius: 8px; text-transform: uppercase; box-shadow: 0 6px 20px rgba(178,0,0,0.45); transition: all 0.3s ease; cursor: pointer; font-family: inherit; }
    .btn-save:hover { background: linear-gradient(135deg, #CC0000, #990000); transform: scale(1.05); }
    .btn-back { position: relative; overflow: hidden; background: transparent; border: 1px solid #2a2a2a; color: #aaa; font-size: 11px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; padding: 14px 36px; border-radius: 6px; text-decoration: none; display: inline-block; transition: color 0.3s, border-color 0.3s; }
    .btn-back::before { content: ''; position: absolute; inset: 0; background: #1e1e1e; transform: scaleX(0); transform-origin: left; transition: transform 0.3s ease; z-index: 0; }
    .btn-back:hover::before { transform: scaleX(1); }
    .btn-back:hover { color: white; border-color: #3a3a3a; }
    .btn-back span { position: relative; z-index: 1; }
    .form-actions { display: flex; gap: 12px; align-items: center; margin-top: 24px; }
    .validation-msg { font-size: 11px; color: #cc2222; letter-spacing: 1px; margin-top: 4px; display: block; }
</style>
}

<div class="container">
    <div class="page-header">
        <h1>Edit Ticket Type</h1>
        <p>Admin — Edit #@Model.Id</p>
    </div>
    <hr class="section-divider">
    <div class="form-card">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="validation-msg mb-3"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-grid">
                <div class="field-float has-value" id="ff-name">
                    <label asp-for="Name">Name</label>
                    <input asp-for="Name" oninput="setVal('ff-name',this)" />
                    <span asp-validation-for="Name" class="validation-msg"></span>
                </div>
                <div class="field-float has-value" id="ff-emoji">
                    <label asp-for="Emoji">Emoji</label>
                    <input asp-for="Emoji" oninput="setVal('ff-emoji',this)" />
                    <span asp-validation-for="Emoji" class="validation-msg"></span>
                </div>
            </div>
            <div class="form-grid">
                <div class="field-float has-value" id="ff-price">
                    <label asp-for="Price">Price (RON)</label>
                    <input asp-for="Price" type="number" step="0.01" oninput="setVal('ff-price',this)" />
                    <span asp-validation-for="Price" class="validation-msg"></span>
                </div>
                <div class="field-float has-value" id="ff-day">
                    <label asp-for="DayRestriction">Day Restriction</label>
                    <select asp-for="DayRestriction" onchange="setVal('ff-day',this)">
                        <option value="">None</option>
                        <option value="Monday">Monday</option>
                        <option value="Tuesday">Tuesday</option>
                        <option value="Wednesday">Wednesday</option>
                        <option value="Thursday">Thursday</option>
                        <option value="Friday">Friday</option>
                        <option value="Saturday">Saturday</option>
                        <option value="Sunday">Sunday</option>
                    </select>
                </div>
            </div>
            <div class="form-grid">
                <div class="field-float has-value" id="ff-min">
                    <label asp-for="MinSeats">Min Seats</label>
                    <input asp-for="MinSeats" type="number" min="1" oninput="setVal('ff-min',this)" />
                    <span asp-validation-for="MinSeats" class="validation-msg"></span>
                </div>
                <div class="field-float has-value" id="ff-max">
                    <label asp-for="MaxSeats">Max Seats</label>
                    <input asp-for="MaxSeats" type="number" min="1" oninput="setVal('ff-max',this)" />
                    <span asp-validation-for="MaxSeats" class="validation-msg"></span>
                </div>
            </div>
            <label class="field-check">
                <input asp-for="IsActive" type="checkbox" />
                <span>Active — visible to users</span>
            </label>
            <div class="form-actions">
                <button type="submit" class="btn-save">Save Changes</button>
                <a asp-action="Index" class="btn-back"><span>← Back</span></a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function setVal(id, el) { document.getElementById(id).classList.toggle('has-value', !!el.value); }
        document.querySelectorAll('.field-float input, .field-float select').forEach(el => { if (el.value) el.closest('.field-float').classList.add('has-value'); });
    </script>
}