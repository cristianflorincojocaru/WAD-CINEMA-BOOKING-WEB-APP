@model IEnumerable<cinemawebapp.Models.Promotion>

@{
    ViewData["Title"] = "Promotions";
}

@section Styles {
<style>
    .page-header { text-align: center; padding: 60px 0 40px; }
    .page-header h1 { font-size: 36px; font-weight: 700; letter-spacing: 6px; text-transform: uppercase; color: white; margin-bottom: 8px; }
    .page-header p { font-size: 12px; letter-spacing: 4px; text-transform: uppercase; color: #aaa; }
    .top-bar { display: flex; justify-content: flex-end; margin-bottom: 24px; }
    .btn-add {
        background: linear-gradient(135deg, #B20000, #8B0000);
        color: white; font-size: 11px; font-weight: 700;
        letter-spacing: 3px; text-transform: uppercase;
        padding: 12px 28px; border-radius: 6px; text-decoration: none;
        transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(178,0,0,0.4);
        text-align: center;
    }
    .btn-add:hover { background: linear-gradient(135deg, #CC0000, #990000); color: white; transform: scale(1.05); }
    .promos-table { width: 100%; border-collapse: collapse; }
    .promos-table thead tr { border-bottom: 1px solid #8B1A1A; }
    .promos-table th { font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: #8B1A1A; font-weight: 700; padding: 12px 16px; text-align: left; }
    .promos-table td { padding: 16px; color: #ccc; font-size: 13px; border-bottom: 1px solid #1a1a1a; vertical-align: middle; }
    .promos-table tbody tr:hover { background-color: #0f0f0f; }
    .promos-table td:first-child { color: white; font-weight: 700; }
    .action-btn {
        font-size: 10px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
        padding: 6px 14px; border-radius: 4px; text-decoration: none;
        border: 1px solid #2a2a2a; color: #aaa;
        transition: all 0.2s ease; display: inline-block; margin-right: 4px;
        text-align: center;
    }
    .action-btn:hover { border-color: white; color: white; }
    .action-btn.delete { border-color: #5a0000; color: #cc2222; }
    .action-btn.delete:hover { background-color: #8B1A1A; color: white; border-color: #8B1A1A; }
    .badge-status { font-size: 9px; letter-spacing: 2px; text-transform: uppercase; padding: 3px 8px; border-radius: 4px; font-weight: 700; }
    .badge-active { background-color: #1a2a1a; color: #4caf50; }
    .badge-inactive { background-color: #2a1a1a; color: #8B1A1A; }
    .desc-cell { max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: #666; font-size: 12px; }
</style>
}

<div class="container">
    <div class="page-header">
        <h1>Promotions</h1>
        <p>Database — All Promotions</p>
    </div>

    <div class="top-bar">
        <a asp-action="Create" class="btn-add">+ Add Promotion</a>
    </div>

    <table class="promos-table">
        <thead>
            <tr>
                <th>Emoji</th>
                <th>Title</th>
                <th>Description</th>
                <th>Discount</th>
                <th>Valid From</th>
                <th>Valid Until</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td style="font-size:20px;">@item.Emoji</td>
                    <td>@item.Title</td>
                    <td class="desc-cell">@item.Description</td>
                    <td>@item.DiscountPercent%</td>
                    <td>@item.ValidFrom.ToString("dd MMM yyyy")</td>
                    <td>@item.ValidUntil.ToString("dd MMM yyyy")</td>
                    <td>
                        @if (item.IsActive)
                        {
                            <span class="badge-status badge-active">Active</span>
                        }
                        else
                        {
                            <span class="badge-status badge-inactive">Inactive</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="action-btn">Details</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="action-btn">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="action-btn delete">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
