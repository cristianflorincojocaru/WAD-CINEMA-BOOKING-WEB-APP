@page
@model RegisterModel
@{ ViewData["Title"] = "Register"; }

@section Styles {
<style>
    .page-header { text-align: center; padding: 60px 0 40px; }
    .page-header h1 { font-size: 36px; font-weight: 700; letter-spacing: 6px; text-transform: uppercase; color: white; margin-bottom: 8px; }
    .page-header p { font-size: 11px; letter-spacing: 4px; text-transform: uppercase; color: #aaa; }
    .section-divider { height: 1px; background: linear-gradient(to right, transparent, #2a2a2a, transparent); border: none; margin: 0 0 40px 0; }
    .form-card { background: #0c0c0c; border: 1px solid #1e1e1e; border-radius: 14px; padding: 40px; max-width: 460px; margin: 0 auto 60px; }
    .field-float { position: relative; background: #141414; border: 1px solid #222; border-radius: 10px; padding: 22px 20px 10px; transition: border-color 0.35s, box-shadow 0.35s; overflow: hidden; margin-bottom: 16px; }
    .field-float::after { content: ''; position: absolute; bottom: 0; left: 50%; height: 2px; width: 0; background: linear-gradient(to right, #7a0000, #ff3333, #7a0000); transform: translateX(-50%); transition: width 0.45s cubic-bezier(0.4,0,0.2,1); border-radius: 2px; }
    .field-float:focus-within { border-color: #2a2a2a; box-shadow: 0 8px 30px rgba(178,0,0,0.1); }
    .field-float:focus-within::after { width: 100%; }
    .field-float label { position: absolute; top: 50%; left: 20px; transform: translateY(-50%); font-size: 11px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: #555; pointer-events: none; transition: all 0.3s cubic-bezier(0.4,0,0.2,1); margin: 0; }
    .field-float:focus-within label, .field-float.has-value label { top: 13px; transform: translateY(0); font-size: 8px; letter-spacing: 4px; color: #8B1A1A; }
    .field-float input { background: transparent !important; color: white !important; border: none !important; outline: none !important; box-shadow: none !important; width: 100%; font-size: 13px; font-weight: 600; letter-spacing: 1px; padding: 0; margin-top: 4px; font-family: inherit; }
    .btn-submit { background: linear-gradient(135deg, #B20000, #8B0000); border: none; color: white; font-weight: 900; letter-spacing: 3px; padding: 14px 48px; font-size: 12px; border-radius: 8px; text-transform: uppercase; box-shadow: 0 6px 20px rgba(178,0,0,0.45); transition: all 0.3s ease; cursor: pointer; font-family: inherit; width: 100%; }
    .btn-submit:hover { background: linear-gradient(135deg, #CC0000, #990000); box-shadow: 0 8px 28px rgba(204,0,0,0.65); transform: scale(1.02); }
    .auth-link { font-size: 11px; letter-spacing: 2px; color: #555; text-decoration: none; text-transform: uppercase; transition: color 0.2s; }
    .auth-link:hover { color: #aaa; }
    .validation-msg { font-size: 11px; color: #cc2222; letter-spacing: 1px; margin-top: 4px; display: block; }
</style>
}

<div class="container">
    <div class="page-header">
        <h1>Register</h1>
        <p>Create your Film Vault account</p>
    </div>
    <hr class="section-divider">
    <div class="form-card">
        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="validation-msg mb-3"></div>

            <div class="field-float" id="ff-email">
                <label asp-for="Input.Email">Email</label>
                <input asp-for="Input.Email" autocomplete="username" oninput="setVal('ff-email',this)" />
                <span asp-validation-for="Input.Email" class="validation-msg"></span>
            </div>

            <div class="field-float" id="ff-pass">
                <label asp-for="Input.Password">Password</label>
                <input asp-for="Input.Password" type="password" autocomplete="new-password" oninput="setVal('ff-pass',this)" />
                <span asp-validation-for="Input.Password" class="validation-msg"></span>
            </div>

            <div class="field-float" id="ff-confirm">
                <label asp-for="Input.ConfirmPassword">Confirm Password</label>
                <input asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password" oninput="setVal('ff-confirm',this)" />
                <span asp-validation-for="Input.ConfirmPassword" class="validation-msg"></span>
            </div>

            <button type="submit" class="btn-submit">Create Account</button>

            <div class="text-center mt-4">
                <a asp-page="./Login" class="auth-link">Already have an account? Log in</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function setVal(id, el) { document.getElementById(id).classList.toggle('has-value', !!el.value); }
        document.querySelectorAll('.field-float input').forEach(el => { if (el.value) el.closest('.field-float').classList.add('has-value'); });
    </script>
}